@* Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eyelix Eyewear</title>

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Prosto+One&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/search.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <!-- Favicon -->
    <link rel="icon" href="~/images/logo/favicon.png" sizes="32x32">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="@(User.Identity.IsAuthenticated ? "authenticated" : "")">
    <!-- Header -->
    @await Html.PartialAsync("_Header")

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer -->
    @await Html.PartialAsync("_Footer")

    <!-- Scripts (jQuery phải load trước cart.js) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
            crossorigin="anonymous"></script>
    <script>
        if (typeof jQuery == 'undefined') {
            document.write('<script src="~/lib/jquery/jquery.min.js"><\/script>');
        }
    </script>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/main.js" asp-append-version="true"></script>
    <script src="~/js/products.js" asp-append-version="true"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>
    <script src="~/js/search.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @* ── Hiển thị toast từ TempData (dùng cho Buy Now, các redirect thông thường) ── *@
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        position: 'top-end',
                        icon: 'success',
                        title: '@TempData["SuccessMessage"]',
                        showConfirmButton: false,
                        timer: 1500,
                        toast: true
                    });
                }
                // Cập nhật số giỏ hàng sau khi trang load (TempData nghĩa là vừa có thao tác cart)
                if (typeof updateHeaderCartCount === 'function') {
                    updateHeaderCartCount();
                }
            });
        </script>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        position: 'top-end',
                        icon: 'error',
                        title: '@TempData["ErrorMessage"]',
                        showConfirmButton: false,
                        timer: 2000,
                        toast: true
                    });
                }
            });
        </script>
    }
</body>
</html>
