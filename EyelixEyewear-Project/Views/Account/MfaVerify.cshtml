@model EyelixEyewear_Project.Models.ViewModels.MfaVerifyViewModel
@{
    ViewData["Title"] = "Xác thực 2 bước";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eyelix Eyewear</title>
    <link rel="stylesheet" href="~/css/forgot-password.css">
        <link rel="icon" href="~/images/logo/favicon.png" sizes="32x32">
            <style>
                    .otp-box { text-align: center; padding: 50px 40px; }
                    .shield-icon { width: 80px; height: 80px; margin: 0 auto 20px; color: #f08438; }
                    .otp-input-group { display: flex; gap: 10px; justify-content: center; margin: 25px 0; }
                    .otp-single { width: 50px; height: 60px; text-align: center; font-size: 24px; font-weight: 700; border: 2px solid #ddd; border-radius: 10px; transition: all 0.2s; }
                    .otp-single:focus { border-color: #f08438; outline: none; box-shadow: 0 0 0 3px rgba(240,132,56,0.15); }
                    .timer-bar { height: 4px; background: #eee; border-radius: 2px; margin: 15px 0; overflow: hidden; }
                    .timer-fill { height: 100%; background: linear-gradient(90deg, #f08438, #e53935); transition: width 1s linear; }
                    .timer-text { font-size: 13px; color: #999; margin-bottom: 20px; }
                    .btn-verify { width: 100%; padding: 12px; background: #000; color: white; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
                    .btn-verify:hover { background: #333; }
                    .info-box { background: #f9f9f9; border-left: 3px solid #f08438; padding: 12px 15px; border-radius: 6px; margin: 20px 0; font-size: 13px; color: #555; text-align: left; }
            </style>
        </head>
        <body>
            <header class="login-header">
                <div class="header-container">
                    <a href="@Url.Action("Index", "Home")" class="logo">
                        <img src="~/images/logo/eyelix-logo.png" alt="Eyelix Eyewear">
                        </a>
                    </div>
                </header>

                <main class="forgot-main">
                    <div class="forgot-container" style="max-width: 460px;">
                        <div class="forgot-content">
                            <div class="forgot-box otp-box">

                                <!-- Icon -->
                                <div class="shield-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                        <polyline points="9 12 11 14 15 10" />
                                    </svg>
                                </div>

                                <h1 style="font-size: 20px; font-weight: 700; margin-bottom: 8px;">Xác thực 2 bước</h1>
                                <p style="color: #777; font-size: 14px; margin-bottom: 5px;">
                                    Mở ứng dụng <strong>Google Authenticator</strong> và nhập mã 6 số.
                                </p>

                                <!-- Timer Bar -->
                                <div class="timer-bar">
                                    <div class="timer-fill" id="timerFill"></div>
                                </div>
                                <div class="timer-text">Mã mới trong <span id="countdown">30</span>s</div>

                                @if (!ViewData.ModelState.IsValid)
                                {
                                    <div style="color: #e53935; background: #fff5f5; border: 1px solid #ffcdd2; padding: 10px; border-radius: 8px; font-size: 13px; margin-bottom: 15px;">
                                        @Html.ValidationSummary(false)
                                    </div>
                                }

                                <form asp-action="MfaVerify" method="post">
                                    <!-- OTP Input (6 ô riêng biệt — UX đẹp hơn) -->
                                    <div class="otp-input-group" id="otpGroup">
                                        @for (int i = 0; i < 6; i++)
                                        {
                                            <input type="text" maxlength="1" class="otp-single"
                                                   inputmode="numeric" pattern="[0-9]"
                                                   id="otp_@i" autocomplete="off">
                                        }
                                    </div>
                                    <!-- Hidden input tổng hợp gửi lên server -->
                                    <input type="hidden" asp-for="OtpCode" id="OtpCode">

                                        <div class="info-box">
                                            Không tìm thấy mã? Kiểm tra ứng dụng <strong>Google Authenticator</strong> hoặc <strong>Authy</strong> trên điện thoại của bạn.
                                        </div>

                                        <button type="submit" class="btn-verify" id="verifyBtn">
                                            Xác nhận →
                                        </button>
                                    </form>

                                </div>
                                <div class="back-box" style="text-align: center; margin-top: 15px;">
                                    <a asp-action="Logout" style="font-size: 13px; color: #999;">← Đăng xuất và thử lại</a>
                                </div>
                            </div>
                        </div>
                    </main>

                    <script>
                            // === 6 OTP Boxes — auto-focus khi gõ ===
                            const boxes = document.querySelectorAll('.otp-single');
                            const hiddenInput = document.getElementById('OtpCode');

                            boxes.forEach((box, idx) => {
                                box.addEventListener('input', (e) => {
                                    const val = e.target.value.replace(/[^0-9]/g, '');
                                    e.target.value = val;
                                    if (val && idx < 5) boxes[idx + 1].focus();
                                    updateHidden();
                                });

                                box.addEventListener('keydown', (e) => {
                                    if (e.key === 'Backspace' && !e.target.value && idx > 0) {
                                        boxes[idx - 1].focus();
                                    }
                                });

                                box.addEventListener('paste', (e) => {
                                    e.preventDefault();
                                    const paste = e.clipboardData.getData('text').replace(/[^0-9]/g, '').slice(0, 6);
                                    paste.split('').forEach((char, i) => {
                                        if (boxes[i]) boxes[i].value = char;
                                    });
                                    updateHidden();
                                    if (paste.length === 6) boxes[5].focus();
                                });
                            });

                            function updateHidden() {
                                hiddenInput.value = Array.from(boxes).map(b => b.value).join('');
                            }

                            // === Countdown Timer (30s TOTP cycle) ===
                            function updateTimer() {
                                const now = Math.floor(Date.now() / 1000);
                                const remaining = 30 - (now % 30);
                                const percent = (remaining / 30) * 100;
                                document.getElementById('countdown').textContent = remaining;
                                document.getElementById('timerFill').style.width = percent + '%';
                            }

                            updateTimer();
                            setInterval(updateTimer, 1000);

                            // Auto-focus ô đầu tiên
                            boxes[0].focus();
                    </script>
                </body>
            </html>