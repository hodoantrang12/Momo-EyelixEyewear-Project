@model EyelixEyewear_Project.Models.ViewModels.CartViewModel
@{
    ViewBag.Title = "Shopping Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
    <style>
        .cart-page {
            padding-top: 120px !important;
            min-height: calc(100vh - 200px);
        }

        /* ── Select All bar ── */
        .select-all-bar {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px 12px 16px;
            border-bottom: 1px solid #e8e8e8;
            margin-bottom: 8px;
            font-size: 13px;
            color: #555;
        }
        .select-all-bar input[type="checkbox"] {
            width: 15px;
            height: 15px;
            accent-color: #000;
            cursor: pointer;
            flex-shrink: 0;
        }
        .select-all-bar label { cursor: pointer; user-select: none; }

        /* ── Cart row override ── */
        .cart-item {
            display: grid;
            /* product | qty | subtotal+checkbox | remove */
            grid-template-columns: 1fr 140px 140px 36px;
            align-items: center;
            gap: 12px;
            padding: 16px 0;
            border-bottom: 1px solid #f0f0f0;
        }

        /* Subtotal + checkbox inline */
        .cart-subtotal-cell {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
        }
        .cart-subtotal-cell .subtotal-amount {
            font-weight: 500;
            font-size: 14px;
            white-space: nowrap;
        }
        .item-checkbox {
            width: 15px;
            height: 15px;
            accent-color: #000;
            cursor: pointer;
            flex-shrink: 0;
        }

        /* Remove button */
        .cart-remove .remove-item {
            background: none;
            border: none;
            font-size: 18px;
            color: #bbb;
            cursor: pointer;
            padding: 2px 6px;
            line-height: 1;
            border-radius: 4px;
            transition: color 0.15s;
        }
        .cart-remove .remove-item:hover { color: #e53935; }

        /* Checkout button */
        .btn-checkout-selected {
            display: block;
            width: 100%;
            padding: 13px;
            background: #000;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-align: center;
            margin-bottom: 10px;
            transition: background 0.2s;
        }
        .btn-checkout-selected:hover    { background: #222; }
        .btn-checkout-selected:disabled { background: #bbb; cursor: not-allowed; }
    </style>
}

<div class="cart-page">
    <div class="cart-layout">
        @if (Model.CartItems != null && Model.CartItems.Any())
        {
            <h1 class="cart-title">Shopping Cart</h1>

            <form id="checkoutSelectedForm"
                  asp-controller="Order"
                  asp-action="CheckoutSelected"
                  method="post">
                @Html.AntiForgeryToken()

                <div class="cart-grid">
                    <div class="cart-items-section">

                        @* ── Select All bar ── *@
                        <div class="select-all-bar">
                            <input type="checkbox" id="selectAll" />
                            <label for="selectAll">Chọn tất cả (@Model.CartItems.Count sản phẩm)</label>
                        </div>

                        @* ── Header ── *@
                        <div class="cart-table-header"
                             style="grid-template-columns:1fr 140px 140px 36px; display:grid; gap:12px; padding:0 0 8px 0; font-size:12px; color:#999; text-transform:uppercase; letter-spacing:.05em;">
                            <span>Product</span>
                            <span style="text-align:center;">Quantity</span>
                            <span style="text-align:right; padding-right:25px;">Subtotal</span>
                            <span></span>
                        </div>

                        @* ── Items ── *@
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="cart-item" data-product-id="@item.ProductId">

                                @* Col 1: Product info *@
                                <div class="cart-item-left">
                                    <img src="@item.ProductImage"
                                         alt="@item.ProductName"
                                         class="cart-thumb"
                                         onerror="this.src='/images/default.png'">
                                    <div class="cart-info">
                                        <div class="name">@item.ProductName</div>
                                        <div class="price" style="font-size:13px; color:#666;">
                                            @item.Price.ToString("N0") VND
                                        </div>
                                    </div>
                                </div>

                                @* Col 2: Quantity *@
                                <div class="quantity-box" style="justify-content:center;">
                                    <button type="button" class="qty-btn minus" data-product-id="@item.ProductId">−</button>
                                    <input type="text"
                                           class="qty-input"
                                           value="@item.Quantity"
                                           data-product-id="@item.ProductId"
                                           data-unit-price="@item.Price"
                                           readonly>
                                    <button type="button" class="qty-btn plus" data-product-id="@item.ProductId">+</button>
                                </div>

                                @* Col 3: Subtotal + Checkbox *@
                                <div class="cart-subtotal-cell">
                                    <span class="subtotal-amount" id="subtotal-@item.ProductId">
                                        @((item.Price * item.Quantity).ToString("N0")) VND
                                    </span>
                                    <input type="checkbox"
                                           name="selectedIds"
                                           value="@item.ProductId"
                                           class="item-checkbox"
                                           checked
                                           title="Chọn sản phẩm này" />
                                </div>

                                @* Col 4: Remove *@
                                <div class="cart-remove">
                                    <button type="button"
                                            class="remove-item"
                                            data-product-id="@item.ProductId"
                                            title="Xóa">×</button>
                                </div>
                            </div>
                        }
                    </div>

                    @* ── Right: Summary ── *@
                    <div class="cart-summary">
                        <h2>Cart totals</h2>

                        <div class="summary-row">
                            <span>Subtotal (đã chọn)</span>
                            <span id="selectedSubtotalDisplay">@Model.Subtotal.ToString("N0") VND</span>
                        </div>

                        <div class="summary-row" style="border-top:1px solid #ddd;padding-top:15px;margin-top:5px;">
                            <span style="font-weight:600;">Shipping</span>
                            <div></div>
                        </div>

                        <p class="vat-info">
                            (includes <span id="vatDisplay">@(((Model.Subtotal + 20000) * 0.08m).ToString("N0"))</span> VND VAT)
                        </p>

                        <button type="submit" class="btn-checkout-selected" id="btnCheckoutSelected">
                            Checkout selected (<span id="selectedCount">@Model.CartItems.Count</span>)
                        </button>

                        <a href="@Url.Action("Checkout", "Order")"
                           style="display:block;text-align:center;color:#888;font-size:12px;text-decoration:underline;margin-top:6px;">
                            Hoặc thanh toán tất cả →
                        </a>
                    </div>
                </div>
            </form>
        }
        else
        {
            <div style="text-align:center;padding:100px 20px;">
                <div style="font-size:80px;margin-bottom:20px;">🛒</div>
                <h2 style="font-size:28px;margin-bottom:10px;">Your cart is empty</h2>
                <p style="color:#777;margin-bottom:30px;">Looks like you haven't added any items yet.</p>
                <a href="@Url.Action("Index", "Product")"
                   style="display:inline-block;padding:12px 40px;background:#000;color:white;border-radius:8px;text-decoration:none;">
                    Start Shopping
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    var unitPrices = {};
    document.querySelectorAll('.qty-input').forEach(function (el) {
        unitPrices[el.dataset.productId] = parseFloat(el.dataset.unitPrice) || 0;
    });

    var selectAllCb = document.getElementById('selectAll');
    var itemCbs     = document.querySelectorAll('.item-checkbox');

    if (selectAllCb) {
        selectAllCb.addEventListener('change', function () {
            itemCbs.forEach(function (cb) { cb.checked = selectAllCb.checked; });
            updateSummary();
        });
    }

    itemCbs.forEach(function (cb) {
        cb.addEventListener('change', function () {
            selectAllCb.checked = Array.from(itemCbs).every(function (c) { return c.checked; });
            updateSummary();
        });
    });

    function updateSummary() {
        var total = 0, count = 0;
        itemCbs.forEach(function (cb) {
            if (cb.checked) {
                var pid   = cb.value;
                var input = document.querySelector('.qty-input[data-product-id="' + pid + '"]');
                var qty   = parseInt(input ? input.value : 1) || 1;
                total += (unitPrices[pid] || 0) * qty;
                count++;
            }
        });
        var el = document.getElementById('selectedSubtotalDisplay');
        var vt = document.getElementById('vatDisplay');
        var ct = document.getElementById('selectedCount');
        var bn = document.getElementById('btnCheckoutSelected');
        if (el) el.textContent = total.toLocaleString('vi-VN') + ' VND';
        if (vt) vt.textContent = Math.round((total + 20000) * 0.08).toLocaleString('vi-VN');
        if (ct) ct.textContent = count;
        if (bn) bn.disabled   = (count === 0);
    }

    document.getElementById('checkoutSelectedForm').addEventListener('submit', function (e) {
        if (!Array.from(itemCbs).some(function (cb) { return cb.checked; })) {
            e.preventDefault();
            alert('Vui lòng chọn ít nhất một sản phẩm để thanh toán.');
        }
    });

    document.querySelectorAll('.qty-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var pid   = btn.dataset.productId;
            var input = document.querySelector('.qty-input[data-product-id="' + pid + '"]');
            var qty   = parseInt(input.value);
            if (btn.classList.contains('plus'))  qty = Math.min(qty + 1, 999);
            if (btn.classList.contains('minus')) qty = Math.max(qty - 1, 1);
            input.value = qty;
            var sub = document.getElementById('subtotal-' + pid);
            if (sub) sub.textContent = ((unitPrices[pid] || 0) * qty).toLocaleString('vi-VN') + ' VND';
            fetch('/Order/UpdateCart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'productId=' + pid + '&quantity=' + qty + '&__RequestVerificationToken=' + getToken()
            });
            updateSummary();
        });
    });

    document.querySelectorAll('.remove-item').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var pid = btn.dataset.productId;
            fetch('/Order/RemoveFromCart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'productId=' + pid + '&__RequestVerificationToken=' + getToken()
            }).then(function (r) { return r.json(); }).then(function (d) {
                if (d.success) {
                    var row = document.querySelector('.cart-item[data-product-id="' + pid + '"]');
                    if (row) row.remove();
                    delete unitPrices[pid];
                    updateSummary();
                }
            });
        });
    });

    function getToken() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }

    updateSummary();
</script>
}
